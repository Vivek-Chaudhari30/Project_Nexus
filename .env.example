# .env.example --- COPY TO .env AND FILL IN BEFORE FIRST RUN

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Required in all modes:
OPENAI_API_KEY=sk-...

# Required only when PROVIDER_MODE=multi:
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Provider Mode ─────────────────────────────────────────────────────────────
# "openai_only" (default) or "multi"
# Can also be toggled at runtime via the UI without restarting the server.
PROVIDER_MODE=openai_only

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_32_chars_min
POSTGRES_DB=nexus

# ── Tools ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Vector DB ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=nexus-memory

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=generate_with_openssl_rand_hex_32

# ── Observability (optional) ──────────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
