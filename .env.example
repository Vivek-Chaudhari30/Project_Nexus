# .env.example --- COPY TO .env AND FILL IN BEFORE FIRST RUN

# Database
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_min_32_chars_long_please
POSTGRES_DB=nexus

# LLM Providers (all required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Tools
TAVILY_API_KEY=tvly-...

# Vector DB
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=nexus-memory

# Auth
JWT_SECRET=generate_with_openssl_rand_hex_32

# Optional
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
